// Folio · Prisma schema
// El schema real se materializa en F2 (migrations M01-M14).
// Para F0 solo dejamos el datasource configurado; sin modelos todavía.

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

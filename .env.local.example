# Folio · environment template
# Copiá a .env.local y completá. .env.local NUNCA se commitea.

# ─── Database (Supabase Postgres) ─────────────────────────────────────
# Conexión directa para migrations (puerto 5432, sin pgBouncer)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?schema=public"
# Conexión pooled para runtime de la app (pgBouncer, puerto 6543)
DATABASE_URL_POOLED="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?schema=public&pgbouncer=true"

# ─── Supabase ──────────────────────────────────────────────────────────
# Plan: Free al inicio. pgsodium NO se usa — encriptación columnar es
# app-side AES-256-GCM (ver FOLIO_ENC_* abajo).
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Encriptación columnar (PII/PHI app-side) ─────────────────────────
# Generar con: openssl rand -base64 32
# FOLIO_ENC_KEY      — AES-256-GCM para columnas *_cifrado (bytea)
# FOLIO_ENC_HMAC_KEY — HMAC-SHA256 para blind indexes nombre_hash / dni_hash
# CRITICAL: estas keys NUNCA se commiten. Si se filtran, hay que rotar +
# re-encrypt todos los datos cifrados (ver scripts/rotate-enc-key.ts en F12).
FOLIO_ENC_KEY=""
FOLIO_ENC_HMAC_KEY=""

# ─── Aplicación ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3010"
NEXT_PUBLIC_APP_NAME="Folio"

# ─── Google Calendar OAuth (F5) ───────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3010/api/google/callback"

# ─── WhatsApp Cloud API (F6) ──────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ─── Resend email (F3/F9) ─────────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM="Folio <no-reply@folio.app>"

# ─── Vercel Cron (F9) ─────────────────────────────────────────────────
# Secret arbitrario; Vercel lo inyecta como Bearer token cuando crones
# crones llaman a /api/cron/*. Generar con: openssl rand -hex 32
CRON_SECRET=""

# ─── Rate limiting (F11) ──────────────────────────────────────────────
# Upstash Redis (REST). Free tier alcanza para <100 req/seg.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Operator opt-in: cuando true, missing-Upstash-credentials en producción
# falla closed (bloquea el endpoint) en vez de fail-open. Setear ÚNICAMENTE
# después de que (a) Upstash esté provisionado, (b) /api/health reporte
# integrations.upstash_redis=true, y (c) Sentry esté wired para que el
# capture de la misconfig llegue a on-call. Sin esta variable (default),
# el rate-limit es fail-open ante credenciales faltantes — preserva la
# disponibilidad mientras Upstash no esté wired (post-mortem 2026-05-25).
UPSTASH_FAIL_CLOSED=""

# ─── Mercado Pago (suscripción mensual de Folio · M19) ────────────────
# Folio es merchant directo. Este token es de Folio, NO del profesional.
# Crear app en https://www.mercadopago.com.ar/developers/panel/app
# Plan actual: 30.000 ARS/mes (ver lib/mercadopago/client.ts MP_PLAN_PRICE_CENTS).
MP_ACCESS_TOKEN=""              # production token de Folio (server-only)
MP_PUBLIC_KEY=""                # reservado para SDK frontend en el futuro
MP_WEBHOOK_SECRET=""            # "Clave secreta" del panel Webhooks de la app MP
NEXT_PUBLIC_MP_PLAN_PRICE_ARS="30000"  # display only — el cobro real lo determina el server

# ─── Captcha Cloudflare Turnstile (F11) ───────────────────────────────
# Crear sitio en https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── AFIP WSFEv1 (F10/F11) ────────────────────────────────────────────
# "homologacion" (testing) o "produccion". El certificado X.509 + private key
# se sube via UI de /configuracion y vive cifrado en organization.certificado_arca_cifrado.
AFIP_ENV="homologacion"

# ─── Sentry (F11) ─────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ─── PostHog (F11) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# ─── Locale ────────────────────────────────────────────────────────────
TZ="America/Argentina/Cordoba"

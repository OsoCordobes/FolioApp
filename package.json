{
  "name": "folio-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack -p 3010",
    "build": "next build --turbopack",
    "start": "next start -p 3010",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --test --conditions react-server --import tsx \"tests/unit/**/*.test.ts\"",
    "test:visual": "playwright test --project=prototype",
    "test:visual:update": "playwright test --project=prototype --update-snapshots",
    "test:app": "playwright test --project=app",
    "test:all": "playwright test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "framer-motion": "11.11.0",
    "googleapis": "^171.4.0",
    "next": "15.5.18",
    "node-forge": "^1.4.0",
    "posthog-js": "^1.374.0",
    "posthog-node": "^5.34.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20",
    "@types/node-forge": "^1.3.14",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "pg": "^8.21.0",
    "serve": "^14.2.6",
    "supabase": "^2.98.2",
    "tsx": "^4.22.1",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "supabase",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10",
      "@hono/node-server@<1.19.13": ">=1.19.13"
    }
  }
}
